<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <title>JAKUB GAMES - WYBUCHOWY SYSTEM</title>
    <style>
        body { background-color: #050505; color: #00ff41; font-family: 'Courier New', monospace; text-align: center; margin: 0; overflow-x: hidden; }

        /* --- EFEKT WYBUCHU I PREZENTACJI --- */
        @keyframes explosion {
            0% { transform: scale(0.1); opacity: 0; filter: brightness(10); }
            50% { transform: scale(1.2); opacity: 1; filter: brightness(2); }
            100% { transform: scale(1); opacity: 1; filter: brightness(1); }
        }
        @keyframes shake {
            0% { transform: translate(1px, 1px); }
            20% { transform: translate(-3px, -2px); }
            40% { transform: translate(3px, 2px); }
            100% { transform: translate(0, 0); }
        }
        .smoke-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle, #444, #111, #000);
            z-index: 10001; display: flex; justify-content: center; align-items: center;
            animation: explosion 0.8s ease-out;
        }
        .blast-box { animation: shake 0.5s infinite; }

        /* --- STYLIZACJA PANELU --- */
        .main-container { border: 2px solid #00ff41; padding: 30px; margin-top: 50px; display: inline-block; background: #000; box-shadow: 0 0 20px #00ff41; }
        .btn-action { background: #00ff41; color: black; padding: 15px 30px; font-weight: bold; border: none; cursor: pointer; margin-top: 20px; font-size: 1.2em; }
        .btn-action:hover { background: white; box-shadow: 0 0 20px white; }
        input { background: #111; border: 1px solid #00ff41; color: #00ff41; padding: 10px; margin: 10px; text-align: center; }
    </style>
</head>
<body>

    <div id="explosion-screen" class="smoke-bg">
        <div class="blast-box">
            <h1 style="font-size: 4em; color: #ff4500; text-shadow: 0 0 20px red;">💥 BOOM! 💥</h1>
            <h2 style="color: white;">JAKUB GAMES: SYSTEM ODPALONY</h2>
            <p style="font-size: 1.5em; color: #00ff41;">Hej! Zaloguj się, ta gra jest bardzo super!</p>
            <button class="btn-action" onclick="detonate()">WCHODZĘ DO GRY</button>
        </div>
    </div>

    <div class="main-container">
        <h1>JAKUB GAMES OS</h1>
        <p>[ STATUS: OCZEKIWANIE NA ADMINISTRATORA ]</p>
        <hr style="border-color: #00ff41;">
        
        <div id="admin-zone">
            <h3>🔐 STREFA BEZPIECZEŃSTWA</h3>
            <p>Wpisz pierwszy kod (1212):</p>
            <input type="password" id="pass1" placeholder="KOD 1">
            <br>
            <button class="btn-action" onclick="startSecurity()">URUCHOM SKANOWANIE</button>
        </div>
    </div>

    <script>
        // Funkcja zamykająca wybuch
        function detonate() {
            document.getElementById('explosion-screen').style.filter = 'brightness(10)';
            setTimeout(() => {
                document.getElementById('explosion-screen').style.display = 'none';
            }, 200);
        }

        // System zabezpieczeń
        function startSecurity() {
            let p1 = document.getElementById('pass1').value;
            
            if(p1 === "1212") {
                alert("KOD 1 POPRAWNY. Rozpoczynam skanowanie głosu...");
                
                // Uruchomienie mikrofonu
                window.SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
                if (!window.SpeechRecognition) {
                    alert("Twoja przeglądarka nie obsługuje skanera głosu!");
                    return;
                }

                const recognition = new SpeechRecognition();
                recognition.lang = 'pl-PL';
                recognition.start();

                alert("MÓW TERAZ! (System sprawdza głos Jakuba)");

                recognition.onresult = function(event) {
                    let glos = event.results[0][0].transcript.toLowerCase();
                    if(glos.includes("jakub") || glos.includes("otwórz") || glos.includes("ja")) {
                        alert("GŁOS ZWERYFIKOWANY. Podaj hasło ostateczne:");
                        
                        // Drugie hasło: 4BBwf
                        let p2 = prompt("WPISZ HASŁO (4 + 2x duże B + w + f):");
                        if(p2 === "4BBwf") {
                            alert("WITAJ JAKUBIE! Pełny dostęp do Słonków i Wind przyznany.");
                            document.body.style.background = "#001a33";
                        } else {
                            alert("ALARM! BŁĘDNE HASŁO OSTATECZNE!");
                        }
                    } else {
                        alert("BŁĄD: To nie jest głos administratora!");
                    }
                };
            } else {
                alert("BŁĄD: Niepoprawny pierwszy kod!");
            }
        }
    </script>
</body>
</html>
